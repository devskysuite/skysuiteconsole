{
  "hosting": {
    "public": "dashboard/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/ics", "function": "serveIcs", "region": "us-central1" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "scheduled-tasks",
      "runtime": "nodejs22"
    }
  ],
  "storage": {
    "rules": "storage.rules"
  }
}
